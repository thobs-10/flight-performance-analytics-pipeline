LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Dagster
DAGSTER_HOME=/absolute/path/to/project/.dagster_home

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB=flight_performance_raw

# ClickHouse connection (gold analytical layer)
# CLICKHOUSE_PORT: 8123 = HTTP interface (used by clickhouse-connect)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DATABASE=gold
